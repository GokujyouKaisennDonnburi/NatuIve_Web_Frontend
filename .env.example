# このファイルはローカル開発用のテンプレート。コピーして .env.local を作る（cp .env.example .env.local）。

# 開発サーバの待ち受けポート
PORT=3000

# API のベース URL。画像/PDF の presign（POST /api/v1/uploads/presign）や
# イベント取得・作成など、すべての API 呼び出し先になる。
# 未設定なら同一オリジンの相対パス（開発時は MSW がモックを返す）。
# 実際に投稿（R2 アップロード）したい場合は実 API のオリジンを設定する。

# 未設定だと presign が実 API に届かず署名 URL を取得できないため、
# 実際に画像/PDF を投稿するには実 API のオリジンを設定する。
# ...ということ
# 例（ローカル API）: http://localhost:8085
# 例（本番）: https://api.natuportal.org
NEXT_PUBLIC_API_BASE_URL=

# Supabase プロジェクト URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase の匿名認証キー
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- R2（Cloudflare）について ---
# 画像/PDF は presign で受け取った署名付き URL に直接 PUT するため、
# フロントエンドに R2 の認証情報は不要（ブラウザに露出するため設定してはいけない）。
# R2_ACCOUNT_ID / R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY / R2_BUCKET は
# API サーバー側（NatuIve_API の .env）に設定する。
